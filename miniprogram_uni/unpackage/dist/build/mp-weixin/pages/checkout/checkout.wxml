<view class="checkout-container"><view class="checkout-body"><view class="page-header"><text data-event-opts="{{[['tap',[['$navigateBack',['$event']]]]]}}" class="page-header-back" bindtap="__e">‹</text><text class="page-header-title">Your Order</text></view><view class="section delivery-section"><view class="delivery-toggle"><view data-event-opts="{{[['tap',[['selectDeliveryType',['delivery']]]]]}}" class="{{['toggle-btn '+(deliveryType==='delivery'?'active':'')]}}" bindtap="__e"><text class="toggle-text">Delivery</text></view><view data-event-opts="{{[['tap',[['selectDeliveryType',['pickup']]]]]}}" class="{{['toggle-btn '+(deliveryType==='pickup'?'active':'')]}}" bindtap="__e"><text class="toggle-text">Pickup</text></view></view><block wx:if="{{deliveryType==='delivery'}}"><view><block wx:if="{{$root.m0>=65}}"><view data-event-opts="{{[['tap',[['openAddressPicker',['$event']]]]]}}" class="delivery-row" bindtap="__e"><text class="delivery-row-label">Address</text><text class="{{['delivery-row-value '+(address==='请选择收货地址'?'placeholder':'')]}}">{{''+(address==='请选择收货地址'?'Please enter your address':address)+''}}</text><text class="arrow">›</text></view></block><block wx:else><view class="delivery-row"><text class="delivery-row-label">MRT</text><input class="mrt-input" placeholder="Please enter your MRT station" data-event-opts="{{[['input',[['e0',['$event']]]]]}}" value="{{mrtStation}}" bindinput="__e"/></view></block></view></block><view data-event-opts="{{[['tap',[['selectTime',['$event']]]]]}}" class="delivery-row" bindtap="__e"><text class="delivery-row-label">{{deliveryType==='delivery'?'Delivery Time':'Pickup Time'}}</text><text class="{{['delivery-row-value '+(deliveryTime?'':'placeholder')]}}">{{deliveryTime||'Select Time'}}</text><text class="arrow">›</text></view></view><view class="section goods-section"><view class="section-header"><text class="section-title">Order Summary</text></view><view class="goods-list"><block wx:for="{{selectedItems}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="goods-item"><image class="goods-image" src="{{item.image}}" mode="aspectFill"></image><view class="goods-info"><text class="goods-name">{{item.name}}</text><block wx:if="{{item.description}}"><text class="goods-desc">{{item.description}}</text></block></view><view class="goods-right"><text class="goods-price">{{"$"+item.price}}</text><text class="goods-quantity">{{"x"+item.quantity}}</text></view></view></block></view></view><view class="section payment-section"><view class="section-header"><text class="section-title">Payment Methods</text></view><view data-event-opts="{{[['tap',[['selectPayment',['wechat']]]]]}}" class="payment-item" bindtap="__e"><image class="payment-icon" src="/static/images/icon/wechat-pay.png" mode="aspectFit"></image><text class="payment-name">WeChat Pay</text><view class="{{['payment-radio '+(paymentMethod==='wechat'?'selected':'')]}}"><block wx:if="{{paymentMethod==='wechat'}}"><text class="payment-check">✓</text></block></view></view><view class="payment-divider"></view><view data-event-opts="{{[['tap',[['selectPayment',['paynow']]]]]}}" class="payment-item" bindtap="__e"><image class="payment-icon" src="/static/images/icon/paynow.png" mode="aspectFit"></image><text class="payment-name">PayNow</text><view class="{{['payment-radio '+(paymentMethod==='paynow'?'selected':'')]}}"><block wx:if="{{paymentMethod==='paynow'}}"><text class="payment-check">✓</text></block></view></view></view><view class="section remark-section"><view class="section-header"><text class="section-title">Order Notes</text></view><textarea class="remark-input" placeholder="Add notes (optional)" adjust-position="{{false}}" maxlength="200" data-event-opts="{{[['input',[['inputRemark',['$event']]]]]}}" bindinput="__e"></textarea></view><block wx:if="{{showAddressPicker}}"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="picker-overlay" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="picker-sheet" catchtap="__e"><view class="picker-header"><text class="picker-title">Select delivery address</text><text data-event-opts="{{[['tap',[['openAddressForm',['$event']]]]]}}" class="addr-add-btn" bindtap="__e">Add</text></view><scroll-view class="addr-list" scroll-y="{{true}}"><block wx:if="{{$root.g0===0}}"><view class="addr-empty"><text class="addr-empty-text">No Address</text></view></block><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="i" wx:key="i"><view data-event-opts="{{[['tap',[['selectAddressItem',['$0'],[[['addressList','',i]]]]]]]}}" class="{{['addr-item '+(selectedAddress&&selectedAddress.id==item.id?'selected':'')]}}" bindtap="__e"><view class="addr-item-info"><text class="addr-item-name">{{item.name+"  "+item.phone}}</text><text class="addr-item-detail">{{item.province+item.city+item.district+item.detail}}</text></view><view class="{{['addr-radio '+(selectedAddress&&selectedAddress.id==item.id?'active':'')]}}"></view></view></block></scroll-view></view></view></block><block wx:if="{{showAddressForm}}"><view class="addr-form-overlay"><view class="addr-form-header"><text data-event-opts="{{[['tap',[['closeAddressForm',['$event']]]]]}}" class="addr-form-close" bindtap="__e">✕</text><text class="addr-form-title">Add new delivery address</text></view><scroll-view class="addr-form-body" scroll-y="{{true}}"><view class="addr-field-group"><view class="addr-field-label">Postal code</view><input class="addr-field-input" placeholder="e.g. 399948" data-event-opts="{{[['input',[['onAddrInput',['postalCode','$event']]]]]}}" value="{{newAddr.postalCode}}" bindinput="__e"/></view><view class="addr-field-group"><view class="addr-field-label">Building name <text class="addr-field-optional">Optional</text></view><input class="addr-field-input" placeholder="Building name" data-event-opts="{{[['input',[['onAddrInput',['building','$event']]]]]}}" value="{{newAddr.building}}" bindinput="__e"/></view><view class="addr-field-group"><view class="addr-field-label">Address</view><input class="addr-field-input" placeholder="Street address" data-event-opts="{{[['input',[['onAddrInput',['address','$event']]]]]}}" value="{{newAddr.address}}" bindinput="__e"/></view><view class="addr-field-row"><view class="addr-field-half"><view class="addr-field-label">Floor</view><input class="addr-field-input" placeholder="e.g. 06" data-event-opts="{{[['input',[['onAddrInput',['floor','$event']]]]]}}" value="{{newAddr.floor}}" bindinput="__e"/></view><view class="addr-field-half"><view class="addr-field-label">Unit number</view><input class="addr-field-input" placeholder="e.g. 31" data-event-opts="{{[['input',[['onAddrInput',['unit','$event']]]]]}}" value="{{newAddr.unit}}" bindinput="__e"/></view></view><view class="addr-recipient-section"><view class="addr-section-title">Recipient's information</view><view class="addr-section-divider"></view></view><view class="addr-field-group"><view class="addr-field-label">Name</view><input class="addr-field-input" placeholder="Full name" data-event-opts="{{[['input',[['onAddrInput',['name','$event']]]]]}}" value="{{newAddr.name}}" bindinput="__e"/></view><view class="addr-field-group"><view class="addr-field-label">Mobile number</view><input class="addr-field-input" placeholder="Phone number" type="number" data-event-opts="{{[['input',[['onAddrInput',['phone','$event']]]]]}}" value="{{newAddr.phone}}" bindinput="__e"/></view></scroll-view><view data-event-opts="{{[['tap',[['saveNewAddress',['$event']]]]]}}" class="addr-form-save" bindtap="__e"><text>Add address</text></view></view></block><block wx:if="{{showTimePicker}}"><view data-event-opts="{{[['tap',[['cancelTime',['$event']]]]]}}" class="picker-overlay" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="picker-sheet" catchtap="__e"><view class="picker-header"><text class="picker-title">Select a time slot</text><text data-event-opts="{{[['tap',[['cancelTime',['$event']]]]]}}" class="picker-cancel" bindtap="__e">Cancel</text></view><scroll-view class="date-tabs" scroll-x="{{true}}" scroll-into-view="{{'date-tab-'+selectedDateIndex}}"><block wx:for="{{dateTabs}}" wx:for-item="tab" wx:for-index="i" wx:key="i"><view class="{{['date-tab '+(selectedDateIndex===i?'active':'')]}}" id="{{'date-tab-'+i}}" data-event-opts="{{[['tap',[['selectDateTab',[i]]]]]}}" bindtap="__e"><text class="date-tab-text">{{tab.label}}</text></view></block></scroll-view><view class="slots-list"><block wx:for="{{currentSlots}}" wx:for-item="slot" wx:for-index="i" wx:key="i"><view data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" data-event-params="{{({slot})}}" class="{{['slot-item '+(!slot.available?'unavailable':tempTime===slot.label?'selected':'')]}}" bindtap="__e"><view class="{{['slot-radio '+(tempTime===slot.label?'active':'')]}}"></view><text class="slot-label">{{slot.label}}</text><block wx:if="{{!slot.available}}"><text class="slot-na">Not available</text></block></view></block></view><view data-event-opts="{{[['tap',[['confirmTime',['$event']]]]]}}" class="{{['picker-confirm '+(tempTime?'':'disabled')]}}" bindtap="__e"><text>Confirm</text></view></view></view></block></view><block wx:if="{{showPaynowPopup}}"><view data-event-opts="{{[['tap',[['closePaynowPopup',['$event']]]]]}}" class="paynow-overlay" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="paynow-popup" catchtap="__e"><view class="paynow-header"><text class="paynow-title">PayNow Payment</text><text data-event-opts="{{[['tap',[['closePaynowPopup',['$event']]]]]}}" class="paynow-close" bindtap="__e">✕</text></view><view class="paynow-body"><view class="paynow-amount-box"><text class="paynow-amount-label">Amount to pay</text><text class="paynow-amount">{{"$ "+totalPrice}}</text></view><view class="paynow-qr-box"><image class="paynow-qr-image" src="/static/images/icon/paynow-qr.png" mode="aspectFit"></image></view><view class="paynow-account-box"><text class="paynow-account-label">Or transfer to PayNow UEN</text><text class="paynow-account-number" selectable="{{true}}">202401234A</text></view><view class="paynow-tips"><text class="paynow-tip">Scan the QR code above or transfer via PayNow UEN.</text><text class="paynow-tip">Please transfer the exact amount shown.</text><text class="paynow-tip-highlight">Payment confirmation takes about 1 minute.</text></view></view><view data-event-opts="{{[['tap',[['confirmPaynowOrder',['$event']]]]]}}" class="{{['paynow-confirm-btn '+(submitting?'disabled':'')]}}" bindtap="__e"><text>{{submitting?'Processing...':'I have paid'}}</text></view></view></view></block><block wx:if="{{footerVisible}}"><view class="checkout-footer"><view data-event-opts="{{[['tap',[['submitOrder',['$event']]]]]}}" class="{{['submit-btn '+(submitting?'disabled':'')]}}" bindtap="__e"><text>{{submitting?'Processing...':'PAY $ '+totalPrice}}</text></view></view></block></view>