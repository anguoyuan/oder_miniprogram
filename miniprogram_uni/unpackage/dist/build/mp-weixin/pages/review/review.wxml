<view class="review-container"><view class="review-header"><text class="header-title">订单评价</text><text class="order-no">{{"订单号："+orderNo}}</text></view><view class="review-section"><view class="section-title"><text>评分</text><text class="rating-text">{{rating+"分"}}</text></view><view class="rating-stars"><block wx:for="{{[1,2,3,4,5]}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['star '+(item<=rating?'active':'')]}}" data-rating="{{item}}" data-event-opts="{{[['tap',[['onRatingChange',['$event']]]]]}}" bindtap="__e"><text>{{item<=rating?'★':'☆'}}</text></view></block></view></view><view class="review-section"><view class="section-title">评价内容</view><textarea class="review-textarea" placeholder="请输入您的评价内容（至少10个字）" maxlength="500" data-event-opts="{{[['input',[['onContentInput',['$event']]]]]}}" value="{{content}}" bindinput="__e"></textarea><view class="char-count">{{$root.g0+"/500"}}</view></view><view class="review-section"><view class="section-title">上传图片（选填，最多3张）</view><view class="image-list"><block wx:for="{{images}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="image-item"><image src="{{item}}" mode="aspectFill" data-index="{{index}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="delete-btn" data-index="{{index}}" data-event-opts="{{[['tap',[['deleteImage',['$event']]]]]}}" bindtap="__e"><text>×</text></view></view></block><block wx:if="{{$root.g1<3}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="add-image" bindtap="__e"><text class="add-icon">+</text><text class="add-text">添加图片</text></view></block></view></view><view class="submit-btn-container"><button class="submit-btn" disabled="{{submitting}}" data-event-opts="{{[['tap',[['submitReview',['$event']]]]]}}" bindtap="__e">{{''+(submitting?'提交中...':'提交评价')+''}}</button></view></view>