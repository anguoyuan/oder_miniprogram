<view class="addr-form-overlay"><view class="addr-form-header" style="{{'padding-top:'+(statusBarHeight+4+'px')+';'}}"><text data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="addr-form-close" bindtap="__e">✕</text><text class="addr-form-title">{{isEdit?'Edit address':'Add new delivery address'}}</text></view><scroll-view class="addr-form-body" scroll-y="{{true}}"><view class="addr-field-group"><view class="addr-field-label">Postal code</view><input class="addr-field-input" placeholder="e.g. 399948" data-event-opts="{{[['input',[['e0',['$event']]]]]}}" value="{{form.postalCode}}" bindinput="__e"/></view><view class="addr-field-group"><view class="addr-field-label">Building name <text class="addr-field-optional">Optional</text></view><input class="addr-field-input" placeholder="Building name" data-event-opts="{{[['input',[['e1',['$event']]]]]}}" value="{{form.building}}" bindinput="__e"/></view><view class="addr-field-group"><view class="addr-field-label">Address</view><input class="addr-field-input" placeholder="Street address" data-event-opts="{{[['input',[['e2',['$event']]]]]}}" value="{{form.detail}}" bindinput="__e"/></view><view class="addr-field-row"><view class="addr-field-half"><view class="addr-field-label">Floor</view><input class="addr-field-input" placeholder="e.g. 06" data-event-opts="{{[['input',[['e3',['$event']]]]]}}" value="{{form.floor}}" bindinput="__e"/></view><view class="addr-field-half"><view class="addr-field-label">Unit number</view><input class="addr-field-input" placeholder="e.g. 31" data-event-opts="{{[['input',[['e4',['$event']]]]]}}" value="{{form.unit}}" bindinput="__e"/></view></view><view class="addr-recipient-section"><view class="addr-section-title">Recipient's information</view><view class="addr-section-divider"></view></view><view class="addr-field-group"><view class="addr-field-label">Name</view><input class="addr-field-input" placeholder="Full name" data-event-opts="{{[['input',[['e5',['$event']]]]]}}" value="{{form.name}}" bindinput="__e"/></view><view class="addr-field-group"><view class="addr-field-label">Mobile number</view><input class="addr-field-input" placeholder="Phone number" type="number" data-event-opts="{{[['input',[['e6',['$event']]]]]}}" value="{{form.phone}}" bindinput="__e"/></view><block wx:if="{{isEdit}}"><view data-event-opts="{{[['tap',[['deleteAddress',['$event']]]]]}}" class="addr-delete-btn" bindtap="__e"><text class="addr-delete-text">Delete this address</text></view></block><view style="height:40rpx;"></view></scroll-view><view data-event-opts="{{[['tap',[['saveAddress',['$event']]]]]}}" class="addr-form-save" bindtap="__e"><text>{{isEdit?'Save Changes':'Add address'}}</text></view></view>