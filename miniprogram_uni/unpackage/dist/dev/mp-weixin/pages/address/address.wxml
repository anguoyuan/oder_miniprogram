<view class="address-page"><view class="nav-bar" style="{{'padding-top:'+(statusBarHeight+'px')+';'+('height:'+(statusBarHeight+44+'px')+';')}}"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back" bindtap="__e">‹</view><text class="nav-title">Address</text><view style="width:60rpx;"></view></view><scroll-view class="addr-scroll" scroll-y="{{true}}"><block wx:if="{{loading}}"><view class="addr-empty"><text class="addr-empty-text">Loading...</text></view></block><block wx:else><block wx:if="{{$root.g0===0}}"><view class="addr-empty"><text class="addr-empty-text">No addresses yet</text></view></block></block><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="i" wx:key="i"><view data-event-opts="{{[['tap',[['setDefault',['$0'],[[['addressList','',i,'id']]]]]]]}}" class="addr-card" bindtap="__e"><view class="addr-card-content"><text class="addr-name">{{item.name+"  "+item.phone}}</text><text class="addr-detail">{{item.province+item.city+item.district+item.detail}}</text><text data-event-opts="{{[['tap',[['editAddress',['$0'],[[['addressList','',i]]]]]]]}}" class="addr-edit" catchtap="__e">Edit</text></view><view class="{{['addr-radio',item.isDefault?'active':'']}}"></view></view></block><view data-event-opts="{{[['tap',[['addAddress',['$event']]]]]}}" class="add-link-row" bindtap="__e"><text class="add-link">+ 添加新地址</text></view></scroll-view></view>