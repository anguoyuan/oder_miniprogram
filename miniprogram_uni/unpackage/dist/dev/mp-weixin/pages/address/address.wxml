<view class="address-container"><block wx:if="{{$root.g0>0}}"><view class="address-list"><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="address-item" data-address="{{item}}" data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" bindtap="__e"><view class="address-header"><view class="user-info"><text class="user-name">{{item.name}}</text><text class="user-phone">{{item.phone}}</text></view><block wx:if="{{item.isDefault}}"><view class="default-tag">默认</view></block></view><view class="address-detail"><text class="address-icon">📍</text><text class="address-text">{{item.province+item.city+item.district+item.detail}}</text></view><view class="address-actions"><view class="action-btn" data-address="{{item}}" data-event-opts="{{[['tap',[['editAddress',['$event']]]]]}}" catchtap="__e"><text class="action-icon">✏️</text><text>编辑</text></view><view class="action-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['deleteAddress',['$event']]]]]}}" catchtap="__e"><text class="action-icon">🗑️</text><text>删除</text></view><block wx:if="{{!item.isDefault}}"><view class="action-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['setDefault',['$event']]]]]}}" catchtap="__e"><text class="action-icon">⭐</text><text>设为默认</text></view></block></view></view></block></view></block><block wx:else><view class="empty-address"><image class="empty-image" src="/static/images/me/shouhuodizhi.png"></image><text class="empty-text">还没有收货地址</text></view></block><view data-event-opts="{{[['tap',[['addAddress',['$event']]]]]}}" class="add-address-btn" bindtap="__e"><text>+ 添加新地址</text></view><block wx:if="{{loading}}"><view class="loading"><text>加载中...</text></view></block></view>