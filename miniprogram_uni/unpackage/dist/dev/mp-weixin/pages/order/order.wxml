<view class="order-container"><view class="custom-nav" style="{{'padding-top:'+(statusBarHeight+'px')+';'+('height:'+(statusBarHeight+44+'px')+';')}}"><text class="custom-nav-title">Order</text></view><view class="main-content" style="{{'height:'+('calc(100vh - '+(statusBarHeight+44)+'px)')+';'}}"><view class="content-section"><view class="category-nav"><scroll-view class="category-scroll" scroll-y="{{true}}"><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['category-item '+(currentCategory===item.id?'active':'')]}}" data-id="{{item.id}}" data-event-opts="{{[['tap',[['selectCategory',['$event']]]]]}}" bindtap="__e"><image class="category-icon" src="{{item.icon}}" mode="aspectFill"></image><text>{{item.name}}</text></view></block></scroll-view></view><view class="product-list"><scroll-view class="product-scroll" scroll-y="{{true}}" scroll-into-view="{{scrollIntoView}}" data-event-opts="{{[['scroll',[['onProductScroll',['$event']]]]]}}" bindscroll="__e"><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="category-section" id="{{'category-'+item.id}}"><view class="category-title">{{item.name}}</view><block wx:for="{{item.products}}" wx:for-item="product" wx:for-index="index1" wx:key="index1"><view class="product-item"><image class="product-image" src="{{product.image}}" mode="aspectFill" data-id="{{product.id}}" data-event-opts="{{[['tap',[['viewProductDetail',['$event']]]]]}}" bindtap="__e"></image><view class="product-info"><view class="product-header"><view class="product-name-wrap"><text class="product-name">{{product.name}}</text><block wx:if="{{product.description}}"><text class="product-name-cn">{{product.description}}</text></block></view><view class="product-actions"><view class="action-icon" data-id="{{product.id}}" data-event-opts="{{[['tap',[['toggleLike',['$event']]]]]}}" catchtap="__e"><text class="{{['icon-text '+(product.isLiked?'liked':'')]}}">{{product.isLiked?'♥':'♡'}}</text></view><view class="action-icon" data-id="{{product.id}}" data-event-opts="{{[['tap',[['toggleFavorite',['$event']]]]]}}" catchtap="__e"><text class="{{['icon-text '+(product.isFavorited?'favorited':'')]}}">{{product.isFavorited?'★':'☆'}}</text></view></view></view><view class="product-bottom"><text class="product-price">{{"$"+product.price}}</text><view class="add-btn" data-product="{{product}}" data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" bindtap="__e"><text>+</text></view></view></view></view></block></view></block></scroll-view></view></view></view><block wx:if="{{cartCount>0}}"><view class="cart-bottom"><view data-event-opts="{{[['tap',[['showCart',['$event']]]]]}}" class="cart-info" bindtap="__e"><view class="cart-icon-wrapper"><image class="cart-icon" src="/static/images/icon/gouwuche.png"></image><view class="cart-badge">{{cartCount}}</view></view><view class="cart-details"><text class="cart-count">{{cartCount+" Item"}}</text><text class="cart-total">{{"$"+totalPrice}}</text></view></view><view data-event-opts="{{[['tap',[['checkout',['$event']]]]]}}" class="checkout-btn" bindtap="__e"><text>Checkout</text></view></view></block><view data-event-opts="{{[['tap',[['hideSpecModal',['$event']]]]]}}" class="{{['spec-modal '+(showSpecModal?'show':'')]}}" bindtap="__e"><view data-event-opts="{{[['tap',[['stopPropagation',['$event']]]]]}}" class="spec-content" catchtap="__e"><view class="spec-header"><image class="spec-image" src="{{selectedProduct.image}}" mode="aspectFill"></image><view class="spec-info"><text class="spec-name">{{selectedProduct.name}}</text><text class="spec-price">{{"$"+selectedProduct.price}}</text></view><view data-event-opts="{{[['tap',[['hideSpecModal',['$event']]]]]}}" class="close-btn" bindtap="__e">×</view></view><view class="spec-options"><view class="spec-group"><text class="spec-label">糖度</text><view class="spec-tags"><block wx:for="{{sugarOptions}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['spec-tag '+(selectedSpecs.sugar===item?'active':'')]}}" data-type="sugar" data-value="{{item}}" data-event-opts="{{[['tap',[['selectSpec',['$event']]]]]}}" bindtap="__e">{{''+item+''}}</view></block></view></view><view class="spec-group"><text class="spec-label">温度</text><view class="spec-tags"><block wx:for="{{temperatureOptions}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['spec-tag '+(selectedSpecs.temperature===item?'active':'')]}}" data-type="temperature" data-value="{{item}}" data-event-opts="{{[['tap',[['selectSpec',['$event']]]]]}}" bindtap="__e">{{''+item+''}}</view></block></view></view><view class="spec-group"><text class="spec-label">加料</text><view class="spec-tags"><block wx:for="{{addOnOptions}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['spec-tag '+(selectedSpecs.addOn===item?'active':'')]}}" data-type="addOn" data-value="{{item}}" data-event-opts="{{[['tap',[['selectSpec',['$event']]]]]}}" bindtap="__e">{{''+item+''}}</view></block></view></view></view><view class="spec-footer"><view class="quantity-control"><view class="quantity-btn" data-type="minus" data-event-opts="{{[['tap',[['changeQuantity',['$event']]]]]}}" bindtap="__e">-</view><text class="quantity-text">{{quantity}}</text><view class="quantity-btn" data-type="plus" data-event-opts="{{[['tap',[['changeQuantity',['$event']]]]]}}" bindtap="__e">+</view></view><view data-event-opts="{{[['tap',[['confirmAddToCart',['$event']]]]]}}" class="confirm-btn" bindtap="__e">加入购物车</view></view></view></view><view data-event-opts="{{[['tap',[['hideCartModal',['$event']]]]]}}" class="{{['cart-modal '+(showCartModal?'show':'')]}}" bindtap="__e"><view data-event-opts="{{[['tap',[['stopPropagation',['$event']]]]]}}" class="cart-content" catchtap="__e"><view class="cart-header"><text class="cart-title">购物车</text><view data-event-opts="{{[['tap',[['clearCart',['$event']]]]]}}" class="clear-btn" bindtap="__e">清空</view></view><scroll-view class="cart-list" scroll-y="{{true}}"><block wx:for="{{cart}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="cart-item"><image class="cart-item-image" src="{{item.image}}" mode="aspectFill"></image><view class="cart-item-info"><text class="cart-item-name">{{item.name}}</text><text class="cart-item-specs">{{item.specs.sugar+" "+item.specs.temperature+" "+item.specs.addOn}}</text><view class="cart-item-bottom"><text class="cart-item-price">{{"$"+item.price}}</text><view class="cart-quantity-control"><view class="cart-quantity-btn" data-cart-id="{{item.cartId}}" data-type="minus" data-event-opts="{{[['tap',[['updateCartQuantity',['$event']]]]]}}" bindtap="__e">-</view><text class="cart-quantity-text">{{item.quantity}}</text><view class="cart-quantity-btn" data-cart-id="{{item.cartId}}" data-type="plus" data-event-opts="{{[['tap',[['updateCartQuantity',['$event']]]]]}}" bindtap="__e">+</view></view></view></view></view></block></scroll-view><view class="cart-footer"><view class="cart-total-info"><text>{{"合计：$"+totalPrice}}</text></view><view data-event-opts="{{[['tap',[['checkout',['$event']]]]]}}" class="cart-checkout-btn" bindtap="__e">Checkout</view></view></view></view></view>