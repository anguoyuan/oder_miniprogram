<view class="review-detail-container"><block wx:if="{{loading}}"><view class="loading-container"><text>加载中...</text></view></block><block wx:else><block wx:if="{{!review}}"><view class="empty-container"><text class="empty-text">暂无评价</text><button data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn" bindtap="__e">返回</button></view></block><block wx:else><view class="content"><view class="header"><text class="title">订单评价</text><text class="order-no">{{"订单号："+orderNo}}</text></view><view class="review-section"><view class="rating-row"><text class="label">评分</text><view class="stars"><block wx:for="{{[1,2,3,4,5]}}" wx:for-item="item" wx:for-index="index" wx:key="index"><text class="{{['star '+(item<=review.rating?'active':'')]}}">{{''+(item<=review.rating?'★':'☆')+''}}</text></block></view></view><view class="content-row"><text class="label">评价内容</text><text class="content-text">{{review.content}}</text></view><block wx:if="{{$root.g0}}"><view class="images-row"><text class="label">评价图片</text><view class="image-list"><block wx:for="{{review.imageList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><image class="review-image" src="{{item}}" mode="aspectFill" data-index="{{index}}" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image></block></view></view></block><view class="time-row"><text class="label">评价时间</text><text class="time-text">{{review.createTime}}</text></view></view><block wx:if="{{review.reply}}"><view class="reply-section"><view class="reply-header"><text class="reply-title">商家回复</text><text class="reply-time">{{review.replyTime}}</text></view><view class="reply-content"><text>{{review.reply}}</text></view></view></block><block wx:else><view class="no-reply"><text>商家暂未回复</text></view></block><view class="btn-container"><button data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-button" bindtap="__e">返回订单列表</button></view></view></block></block></view>