<view class="likes-container"><block wx:if="{{loading}}"><view class="loading"><text>加载中...</text></view></block><block wx:else><block wx:if="{{$root.g0===0}}"><view class="empty"><image class="empty-image" src="/static/images/icon/qucan.png"></image><text class="empty-text">暂无点赞商品</text><navigator class="go-shopping" url="/pages/order/order" open-type="switchTab">去逛逛</navigator></view></block><block wx:else><view class="likes-list"><block wx:for="{{likes}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="like-item"><view class="item-content" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['viewProduct',['$event']]]]]}}" bindtap="__e"><image class="product-image" src="{{item.productImage}}"></image><view class="product-info"><view class="product-name">{{item.productName}}</view><view class="product-desc">{{"销量: "+(item.productSales||0)}}</view><view class="product-price">{{"$"+item.productPrice}}</view></view></view><view class="item-actions"><view class="cancel-btn" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['removeLike',['$event']]]]]}}" bindtap="__e">取消点赞</view><view class="cart-btn" data-product="{{item}}" data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" bindtap="__e">加入购物车</view></view></view></block></view></block></block></view>