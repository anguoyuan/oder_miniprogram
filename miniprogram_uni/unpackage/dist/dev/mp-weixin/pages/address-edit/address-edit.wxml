<view class="address-edit-container"><view class="form-section"><view class="form-item"><text class="form-label">收货人</text><input class="form-input" placeholder="请输入收货人姓名" maxlength="20" data-event-opts="{{[['input',[['inputName',['$event']]]]]}}" value="{{name}}" bindinput="__e"/></view><view class="form-item"><text class="form-label">手机号</text><input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" data-event-opts="{{[['input',[['inputPhone',['$event']]]]]}}" value="{{phone}}" bindinput="__e"/></view><view class="form-item"><text class="form-label">省/州</text><input class="form-input" placeholder="请输入省/州" maxlength="50" data-event-opts="{{[['input',[['inputProvince',['$event']]]]]}}" value="{{province}}" bindinput="__e"/></view><view class="form-item"><text class="form-label">城市</text><input class="form-input" placeholder="请输入城市" maxlength="50" data-event-opts="{{[['input',[['inputCity',['$event']]]]]}}" value="{{city}}" bindinput="__e"/></view><view class="form-item"><text class="form-label">区/县</text><input class="form-input" placeholder="请输入区/县（选填）" maxlength="50" data-event-opts="{{[['input',[['inputDistrict',['$event']]]]]}}" value="{{district}}" bindinput="__e"/></view><view class="form-item form-item-full"><text class="form-label">详细地址</text><textarea class="form-textarea" placeholder="选择位置后自动填入，可手动修改" maxlength="200" auto-height="{{true}}" data-event-opts="{{[['input',[['inputDetail',['$event']]]]]}}" value="{{detail}}" bindinput="__e"></textarea></view><view class="form-item form-item-switch"><text class="form-label">设为默认地址</text><switch checked="{{isDefault}}" color="#AAD08F" data-event-opts="{{[['change',[['toggleDefault',['$event']]]]]}}" bindchange="__e"></switch></view></view><view data-event-opts="{{[['tap',[['saveAddress',['$event']]]]]}}" class="save-btn" bindtap="__e"><text>保存</text></view></view>