<view class="cart-container"><block wx:if="{{$root.g0>0}}"><view class="cart-content"><view class="cart-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="cart-item"><view class="item-check" data-cartid="{{item.$orig.cartId}}" data-event-opts="{{[['tap',[['selectItem',['$event']]]]]}}" bindtap="__e"><view type="{{item.g1>-1?'success':'circle'}}" size="20" color="{{item.g2>-1?'#AAD08F':'#ccc'}}" class="_i"></view></view><image class="item-image" src="{{item.$orig.image}}" mode="aspectFill"></image><view class="item-info"><text class="item-name">{{item.$orig.name}}</text><text class="item-specs">{{item.$orig.specs.sugar+" "+item.$orig.specs.temperature+" "+item.$orig.specs.addOn}}</text><view class="item-bottom"><text class="item-price">{{"¥"+item.$orig.price}}</text><view class="item-quantity"><view class="quantity-btn" data-cartid="{{item.$orig.cartId}}" data-type="minus" data-event-opts="{{[['tap',[['changeQuantity',['$event']]]]]}}" bindtap="__e"><text>-</text></view><text class="quantity-num">{{item.$orig.quantity}}</text><view class="quantity-btn" data-cartid="{{item.$orig.cartId}}" data-type="plus" data-event-opts="{{[['tap',[['changeQuantity',['$event']]]]]}}" bindtap="__e"><text>+</text></view></view></view></view></view></block></view><view class="cart-footer"><view class="footer-left"><view data-event-opts="{{[['tap',[['selectAll',['$event']]]]]}}" class="select-all" bindtap="__e"><view type="{{selectedAll?'success':'circle'}}" size="20" color="{{selectedAll?'#AAD08F':'#ccc'}}" class="_i"></view><text>全选</text></view><text data-event-opts="{{[['tap',[['deleteSelected',['$event']]]]]}}" class="delete-btn" bindtap="__e">删除</text></view><view class="footer-right"><view class="total-info"><text class="total-label">合计：</text><text class="total-price">{{"¥"+totalPrice}}</text></view><view data-event-opts="{{[['tap',[['checkout',['$event']]]]]}}" class="checkout-btn" bindtap="__e"><text>{{"结算("+$root.g3+")"}}</text></view></view></view></view></block><block wx:else><view class="empty-cart"><image class="empty-image" src="/static/images/icon/qucan.png"></image><text class="empty-text">购物车空空如也</text><view data-event-opts="{{[['tap',[['goShopping',['$event']]]]]}}" class="go-shopping-btn" bindtap="__e">去逛逛</view></view></block></view>