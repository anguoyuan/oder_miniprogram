<view class="favorite-container"><block wx:if="{{$root.g0>0}}"><view class="favorite-list"><block wx:for="{{favorites}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="favorite-item" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['viewProduct',['$event']]]]]}}" bindtap="__e"><image class="item-image" src="{{item.productImage}}" mode="aspectFill"></image><view class="item-info"><text class="item-name">{{item.productName}}</text><block wx:if="{{item.productDescription}}"><text class="item-desc">{{item.productDescription}}</text></block><view class="item-bottom"><text class="item-price">{{"$"+item.productPrice}}</text><view class="item-actions"><view class="action-btn add-cart" data-product="{{item}}" data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" catchtap="__e"><text>加入购物车</text></view><view class="action-btn remove" data-id="{{item.productId}}" data-event-opts="{{[['tap',[['removeFavorite',['$event']]]]]}}" catchtap="__e"><text>取消收藏</text></view></view></view></view></view></block></view></block><block wx:else><view class="empty-favorite"><image class="empty-image" src="/static/images/me/shouhuodizhi.png"></image><text class="empty-text">还没有收藏商品哦~</text><view data-event-opts="{{[['tap',[['viewProduct',['$event']]]]]}}" class="go-shopping-btn" bindtap="__e">去逛逛</view></view></block><block wx:if="{{loading}}"><view class="loading"><text>加载中...</text></view></block></view>