<view class="order-list-container"><view class="page-header" style="{{'padding-top:'+(statusBarHeight+6+'px')+';'}}"><text class="page-title">ORDER HISTORY</text><view class="tab-section"><view class="{{['tab-item '+(currentTab==='all'?'active':'')]}}" data-tab="all" data-event-opts="{{[['tap',[['switchTab',['$event']]]]]}}" bindtap="__e"><text>All</text></view><view class="{{['tab-item '+(currentTab==='pending'?'active':'')]}}" data-tab="pending" data-event-opts="{{[['tap',[['switchTab',['$event']]]]]}}" bindtap="__e"><text>Preparing</text></view><view class="{{['tab-item '+(currentTab==='completed'?'active':'')]}}" data-tab="completed" data-event-opts="{{[['tap',[['switchTab',['$event']]]]]}}" bindtap="__e"><text>Finished</text></view></view></view><view class="main-content"><view class="order-content"><block wx:if="{{$root.g0>0}}"><view><block wx:for="{{orders}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="order-item card fade-in"><view class="order-header"><text class="order-id">{{"订单号："+item.orderNo}}</text><view class="{{['order-status status-'+item.status]}}"><text>{{item.statusText}}</text></view></view><view class="order-info"><text class="order-type">{{item.orderType==='takeaway'?'外卖订单':'自取订单'}}</text><text class="order-time">{{item.createTime}}</text></view><view class="order-items"><block wx:for="{{item.items}}" wx:for-item="product" wx:for-index="index1" wx:key="index1"><view class="order-product"><image class="product-image" src="{{product.productImage}}" mode="aspectFill"></image><view class="product-info"><text class="product-name">{{product.productName}}</text><block wx:if="{{product.specs}}"><text class="product-specs">{{product.specs}}</text></block><view class="product-bottom"><text class="product-price">{{"$"+product.price}}</text><text class="product-quantity">{{"x"+product.quantity}}</text></view></view></view></block></view><view class="order-footer"><text class="order-total">{{"合计：$"+item.totalPrice}}</text><view class="order-actions"><block wx:if="{{item.status==='pending'||item.status==='preparing'}}"><view class="action-btn cancel-btn" data-id="{{item.id}}" data-event-opts="{{[['tap',[['cancelOrder',['$event']]]]]}}" bindtap="__e"> 取消订单 </view></block><block wx:if="{{item.status==='completed'}}"><view class="action-btn review-btn" data-id="{{item.id}}" data-no="{{item.orderNo}}" data-reviewed="{{item.hasReview}}" data-event-opts="{{[['tap',[['goToReview',['$event']]]]]}}" bindtap="__e">{{''+(item.hasReview?'查看评价':'去评价')+''}}</view></block></view></view></view></block></view></block><block wx:else><view class="empty-state"><text class="empty-text">No orders yet</text><view data-event-opts="{{[['tap',[['goOrder',['$event']]]]]}}" class="go-order-btn" bindtap="__e">Order Now</view></view></block></view></view></view>