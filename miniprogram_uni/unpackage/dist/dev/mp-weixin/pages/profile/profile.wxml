<view class="profile-container"><scroll-view class="scroll-wrap" style="{{'padding-top:'+(statusBarHeight+20+'px')+';'}}" scroll-y="{{true}}"><view class="user-header"><view class="user-left"><image class="user-avatar" src="{{isLogin?userInfo.avatar:'/static/images/icon/wode.png'}}"></image><view class="user-info-text"><text class="user-name">{{isLogin?userInfo.nickname:'Hello, Guest'}}</text><text class="user-sub">{{isLogin?'已登录':'点击登录'}}</text></view></view><view class="user-right"><block wx:if="{{isLogin}}"><view data-event-opts="{{[['tap',[['handleLogout',['$event']]]]]}}" class="logout-btn" bindtap="__e"><text class="logout-text">退出</text></view></block><block wx:else><view data-event-opts="{{[['tap',[['handleLogin',['$event']]]]]}}" class="login-btn" bindtap="__e"><text class="login-btn-text">登录</text></view></block></view></view><view class="section-title">MY ACCOUNT</view><view class="stats-row"><view data-event-opts="{{[['tap',[['goToOrders',['$event']]]]]}}" class="stats-card" bindtap="__e"><text class="stats-num">{{orderCount}}</text><text class="stats-label">ORDERS</text></view><view class="stats-card"><text class="stats-num">{{"$"+totalSpent}}</text><text class="stats-label">TOTAL SPENT</text></view></view><view class="menu-group"><view data-event-opts="{{[['tap',[['goToOrders',['$event']]]]]}}" class="menu-item" bindtap="__e"><image class="menu-icon" src="/static/images/me/wodedingdan.png"></image><text class="menu-text">我的订单</text><text class="menu-arrow">›</text></view><view class="menu-divider"></view><view class="menu-item" data-type="address" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/shouhuodizhi.png"></image><text class="menu-text">收货地址</text><text class="menu-arrow">›</text></view></view><view class="menu-group" style="margin-top:20rpx;"><view class="menu-item" data-type="usage" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/使用须知.png"></image><text class="menu-text">使用须知</text><text class="menu-arrow">›</text></view><view class="menu-divider"></view><view class="menu-item" data-type="privacy" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/yinsi.png"></image><text class="menu-text">隐私条款</text><text class="menu-arrow">›</text></view><view class="menu-divider"></view><view class="menu-item" data-type="recruitment" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/yuangongzhaopin.png"></image><text class="menu-text">员工招聘</text><text class="menu-arrow">›</text></view></view><view class="version-info"><text class="version-text">v1.0.0</text></view></scroll-view></view>