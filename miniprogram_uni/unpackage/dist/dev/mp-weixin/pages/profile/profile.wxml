<view class="profile-container"><view class="main-content"><view class="user-section"><block wx:if="{{isLogin}}"><view class="user-info card"><image class="user-avatar" src="{{userInfo.avatar}}"></image><view class="user-details"><text class="user-name">{{userInfo.nickname}}</text><text class="user-level">普通会员</text></view><view class="user-actions"><view data-event-opts="{{[['tap',[['goToEditProfile',['$event']]]]]}}" class="edit-btn" bindtap="__e"><text>✏️</text></view><view data-event-opts="{{[['tap',[['handleLogout',['$event']]]]]}}" class="logout-btn" bindtap="__e"><text>退出</text></view></view></view></block><block wx:else><view class="login-section card"><view data-event-opts="{{[['tap',[['handleLogin',['$event']]]]]}}" class="login-prompt" bindtap="__e"><image class="default-avatar" src="/static/images/icon/wode.png"></image><view class="login-text"><text class="login-title">一键登录</text><text class="login-subtitle">登录享受更多优惠</text></view><view class="login-arrow">></view></view></view></block></view><block wx:if="{{isLogin}}"><view class="stats-section card"><view data-event-opts="{{[['tap',[['goToOrders',['$event']]]]]}}" class="stats-item" bindtap="__e"><text class="stats-number">{{orderCount}}</text><text class="stats-label">订单数量</text></view><view class="stats-divider"></view><view class="stats-item"><text class="stats-number">{{"¥"+totalSpent}}</text><text class="stats-label">累计消费</text></view></view></block><view class="menu-section"><view class="menu-group card"><view data-event-opts="{{[['tap',[['goToOrders',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/wodedingdan.png"></image></view><text class="menu-text">我的订单</text><view class="menu-arrow">></view></view><view class="menu-divider"></view><view class="menu-divider"></view><view data-event-opts="{{[['tap',[['goToFavorite',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/huiyuan.png"></image></view><text class="menu-text">我的收藏</text><view class="menu-arrow">></view></view><view class="menu-divider"></view><view data-event-opts="{{[['tap',[['goToLikes',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/dianzan.png"></image></view><text class="menu-text">我的点赞</text><view class="menu-arrow">></view></view><view class="menu-divider"></view><view class="menu-item" data-type="address" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/shouhuodizhi.png"></image></view><text class="menu-text">收货地址</text><view class="menu-arrow">></view></view></view><view class="menu-group card"><view class="menu-item" data-type="usage" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/使用须知.png"></image></view><text class="menu-text">使用须知</text><view class="menu-arrow">></view></view><view class="menu-divider"></view><view class="menu-item" data-type="privacy" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/yinsi.png"></image></view><text class="menu-text">隐私条款</text><view class="menu-arrow">></view></view><view class="menu-divider"></view><view class="menu-item" data-type="recruitment" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><view class="menu-icon"><image class="icon" src="/static/images/me/yuangongzhaopin.png"></image></view><text class="menu-text">员工招聘</text><view class="menu-arrow">></view></view></view></view><view class="version-info"><text class="version-text">一厘米 v1.0.0</text></view></view></view>