<view class="profile-container"><scroll-view class="scroll-wrap" style="{{'padding-top:'+(statusBarHeight+'px')+';'}}" scroll-y="{{true}}"><view class="user-header"><image class="user-avatar" src="{{isLogin?userInfo.avatar:'/static/images/icon/person.png'}}" data-event-opts="{{[['tap',[['handleAvatarTap',['$event']]]]]}}" bindtap="__e"></image><view class="user-info-text"><text class="user-name">{{isLogin?userInfo.nickname:'Hello, Guest'}}</text><text class="user-sub">{{isLogin?'已登录':'点击头像登录'}}</text></view></view><view class="section-title">MY ACCOUNT</view><view class="stats-row"><view data-event-opts="{{[['tap',[['goToOrders',['$event']]]]]}}" class="stats-card" bindtap="__e"><text class="stats-num">{{orderCount}}</text><text class="stats-label">ORDERS</text></view><view class="stats-card"><text class="stats-num">{{totalSpent}}</text><text class="stats-label">NONG COINS</text></view></view><view class="menu-group"><view data-event-opts="{{[['tap',[['goToOrders',['$event']]]]]}}" class="menu-item" bindtap="__e"><image class="menu-icon" src="/static/images/me/orders.png"></image><text class="menu-text">我的订单</text><text class="menu-arrow">›</text></view><view class="menu-divider"></view><view class="menu-item" data-type="address" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/address.png"></image><text class="menu-text">收货地址</text><text class="menu-arrow">›</text></view></view><view class="menu-group" style="margin-top:20rpx;"><view class="menu-item" data-type="usage" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/note.png"></image><text class="menu-text">使用须知</text><text class="menu-arrow">›</text></view><view class="menu-divider"></view><view class="menu-item" data-type="privacy" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/privacy.png"></image><text class="menu-text">隐私条款</text><text class="menu-arrow">›</text></view><view class="menu-divider"></view><view class="menu-item" data-type="recruitment" data-event-opts="{{[['tap',[['handleMenuClick',['$event']]]]]}}" bindtap="__e"><image class="menu-icon" src="/static/images/me/megaphone.png"></image><text class="menu-text">员工招聘</text><text class="menu-arrow">›</text></view></view><block wx:if="{{isLogin}}"><view data-event-opts="{{[['tap',[['handleLogout',['$event']]]]]}}" class="logout-link" bindtap="__e"><text class="logout-link-text">退出登录</text></view></block><view class="version-info"><text class="version-text">v1.0.0</text></view></scroll-view><block wx:if="{{showProfileSetup}}"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="setup-overlay" catchtap="__e"><view class="setup-popup"><text class="setup-title">设置你的资料</text><text class="setup-sub">头像和昵称将用于你的账号</text><button class="avatar-picker-btn" open-type="chooseAvatar" data-event-opts="{{[['chooseavatar',[['handleChooseAvatar',['$event']]]]]}}" bindchooseavatar="__e"><image class="setup-avatar" src="{{tempAvatar||'/static/images/icon/person.png'}}"></image><text class="avatar-hint">点击更换头像</text></button><view class="nickname-wrap"><input class="nickname-input" type="nickname" placeholder="输入你的昵称" data-event-opts="{{[['change',[['handleNicknameChange',['$event']]]],['blur',[['handleNicknameBlur',['$event']]]],['input',[['handleNicknameInput',['$event']]]]]}}" bindchange="__e" bindblur="__e" bindinput="__e"/></view><view class="setup-actions"><view data-event-opts="{{[['tap',[['cancelSetup',['$event']]]]]}}" class="setup-cancel" bindtap="__e"><text class="setup-cancel-text">取消</text></view><view data-event-opts="{{[['tap',[['confirmProfile',['$event']]]]]}}" class="setup-confirm" bindtap="__e"><text class="setup-confirm-text">完成登录</text></view></view></view></view></block></view>