<view class="lottery-container"><view class="main-content"><view class="points-section card"><view class="points-info"><text class="points-label">我的积分</text><text class="points-value">{{userPoints}}</text></view><text class="points-desc">每消费1元得1积分</text></view><view class="lottery-section card"><view class="lottery-title"><text class="title-text">幸运转盘</text><text class="title-desc">消耗100积分转一次</text></view><view class="lottery-wheel"><view class="wheel-bg" style="{{('transform: rotate('+wheelRotation+'deg);')}}"><block wx:for="{{prizes}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['prize-item prize-'+index]}}" style="{{('transform: rotate('+index*45+'deg);')}}"><view class="prize-content" style="{{('transform: rotate(-'+index*45+'deg);')}}"><text class="prize-text">{{item.name}}</text></view></view></block></view><view class="wheel-pointer"></view><view data-event-opts="{{[['tap',[['startLottery',['$event']]]]]}}" class="{{['start-btn '+(isSpinning?'spinning':'')]}}" bindtap="__e"><text>{{isSpinning?'转动中':'开始'}}</text></view></view></view><view class="prizes-section card"><view class="section-title"><text>奖品说明</text></view><view class="prizes-list"><block wx:for="{{prizes}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="prize-desc"><view class="{{['prize-color prize-color-'+index]}}"></view><text class="prize-name">{{item.name}}</text><text class="prize-probability">{{item.probability+"%"}}</text></view></block></view></view><block wx:if="{{$root.g0>0}}"><view class="records-section card"><view class="section-title"><text>中奖记录</text></view><view class="records-list"><block wx:for="{{lotteryRecords}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="record-item"><text class="record-time">{{item.time}}</text><text class="record-prize">{{item.prize}}</text></view></block></view></view></block></view><view data-event-opts="{{[['tap',[['hideResult',['$event']]]]]}}" class="{{['result-modal '+(showResult?'show':'')]}}" bindtap="__e"><view data-event-opts="{{[['tap',[['stopPropagation',['$event']]]]]}}" class="result-content" catchtap="__e"><view class="result-header"><text class="result-title">{{resultTitle}}</text><view data-event-opts="{{[['tap',[['hideResult',['$event']]]]]}}" class="close-result" bindtap="__e">×</view></view><view class="result-body"><image class="result-icon" src="/static/images/shouye/jifen.png"></image><text class="result-text">{{resultText}}</text></view><view class="result-footer"><view data-event-opts="{{[['tap',[['hideResult',['$event']]]]]}}" class="confirm-result" bindtap="__e">确定</view></view></view></view></view>