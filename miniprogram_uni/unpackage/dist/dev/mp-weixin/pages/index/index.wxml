<view class="index-container"><view class="main-content"><view class="hero-section"><image class="hero-image" src="{{banners[0].image}}" mode="aspectFill"></image><view class="hero-mask"></view><view class="hero-content"><text class="brand-name">SHANGHAI PASTRY</text><text class="brand-slogan">寻味海派点心，品味弄堂情怀</text></view></view><view class="action-grid"><view class="action-item" data-type="pickup" data-event-opts="{{[['tap',[['handleOrderType',['$event']]]]]}}" bindtap="__e"><view class="icon-wrapper"><image class="icon-img" src="/static/images/shouye/baozi.png"></image></view><text class="action-label">到店自取</text><text class="action-sub">STORE PICKUP</text></view><view class="action-item" data-type="takeaway" data-event-opts="{{[['tap',[['handleOrderType',['$event']]]]]}}" bindtap="__e"><view class="icon-wrapper"><image class="icon-img" src="/static/images/shouye/delivery.png"></image></view><text class="action-label">外送订餐</text><text class="action-sub">FAST DELIVERY</text></view></view><view class="feature-section"><view class="section-title"><view class="dot"></view><text>今日推荐</text></view><swiper class="ad-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="4000" duration="500"><block wx:for="{{publicAds}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><view class="feature-card"><image class="card-img" src="{{item.image}}" mode="aspectFill"></image><view class="card-info"><text class="item-title">{{item.title}}</text><text class="item-price">{{item.desc}}</text></view></view></swiper-item></block></swiper></view></view></view>