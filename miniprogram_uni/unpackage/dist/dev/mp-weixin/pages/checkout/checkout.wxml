<view class="checkout-container"><block wx:if="{{deliveryType==='delivery'}}"><view class="section address-section"><view class="section-header"><text class="section-icon">📍</text><text class="section-title">收货地址</text></view><view data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" class="address-content" bindtap="__e"><text class="address-text">{{address}}</text><text class="arrow">›</text></view></view></block><view class="section delivery-section"><view class="section-header"><text class="section-icon">🚚</text><text class="section-title">配送方式</text></view><view class="delivery-types"><view class="{{['delivery-item '+(deliveryType==='delivery'?'active':'')]}}" data-type="delivery" data-event-opts="{{[['tap',[['selectDeliveryType',['$event']]]]]}}" bindtap="__e"><text class="delivery-name">外卖配送</text><text class="delivery-desc">预计30-45分钟送达</text></view><view class="{{['delivery-item '+(deliveryType==='pickup'?'active':'')]}}" data-type="pickup" data-event-opts="{{[['tap',[['selectDeliveryType',['$event']]]]]}}" bindtap="__e"><text class="delivery-name">到店自取</text><text class="delivery-desc">预计15-20分钟可取</text></view></view></view><view class="section goods-section"><view class="section-header"><text class="section-icon">🛍️</text><text class="section-title">商品清单</text></view><view class="goods-list"><block wx:for="{{selectedItems}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="goods-item"><image class="goods-image" src="{{item.image}}" mode="aspectFill"></image><view class="goods-info"><text class="goods-name">{{item.name}}</text><text class="goods-specs">{{item.specs.sugar+" "+item.specs.temperature+" "+item.specs.addOn}}</text></view><view class="goods-right"><text class="goods-price">{{"¥"+item.price}}</text><text class="goods-quantity">{{"x"+item.quantity}}</text></view></view></block></view></view><view class="section remark-section"><view class="section-header"><text class="section-icon">📝</text><text class="section-title">订单备注</text></view><textarea class="remark-input" placeholder="请输入备注信息（选填）" maxlength="200" data-event-opts="{{[['input',[['inputRemark',['$event']]]]]}}" value="{{remark}}" bindinput="__e"></textarea></view><view class="checkout-footer"><view class="total-info"><text class="total-label">合计：</text><text class="total-price">{{"¥"+totalPrice}}</text></view><view data-event-opts="{{[['tap',[['submitOrder',['$event']]]]]}}" class="{{['submit-btn '+(submitting?'disabled':'')]}}" bindtap="__e"><text>{{submitting?'提交中...':'提交订单'}}</text></view></view></view>