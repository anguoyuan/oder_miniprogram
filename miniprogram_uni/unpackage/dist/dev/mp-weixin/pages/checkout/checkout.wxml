<view class="checkout-container"><view class="page-header"><text data-event-opts="{{[['tap',[['$navigateBack',['$event']]]]]}}" class="page-header-back" bindtap="__e">‹</text><text class="page-header-title">Your Order</text></view><view class="section delivery-section"><view class="delivery-toggle"><view data-event-opts="{{[['tap',[['selectDeliveryType',['delivery']]]]]}}" class="{{['toggle-btn '+(deliveryType==='delivery'?'active':'')]}}" bindtap="__e"><text class="toggle-text">Delivery</text></view><view data-event-opts="{{[['tap',[['selectDeliveryType',['pickup']]]]]}}" class="{{['toggle-btn '+(deliveryType==='pickup'?'active':'')]}}" bindtap="__e"><text class="toggle-text">Pickup</text></view></view><block wx:if="{{deliveryType==='delivery'}}"><view data-event-opts="{{[['tap',[['selectAddress',['$event']]]]]}}" class="delivery-row" bindtap="__e"><text class="delivery-row-label">Address</text><text class="delivery-row-value">{{address}}</text><text class="arrow">›</text></view></block><view data-event-opts="{{[['tap',[['selectTime',['$event']]]]]}}" class="delivery-row" bindtap="__e"><text class="delivery-row-label">{{deliveryType==='delivery'?'Delivery Time':'Pickup Time'}}</text><text class="{{['delivery-row-value '+(deliveryTime?'':'placeholder')]}}">{{deliveryTime||'Select Time'}}</text><text class="arrow">›</text></view></view><view class="section goods-section"><view class="section-header"><text class="section-title">Order Summary</text></view><view class="goods-list"><block wx:for="{{selectedItems}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="goods-item"><image class="goods-image" src="{{item.image}}" mode="aspectFill"></image><view class="goods-info"><text class="goods-name">{{item.name}}</text><block wx:if="{{item.description}}"><text class="goods-desc">{{item.description}}</text></block></view><view class="goods-right"><text class="goods-price">{{"$"+item.price}}</text><text class="goods-quantity">{{"x"+item.quantity}}</text></view></view></block></view></view><view class="section payment-section"><view class="section-header"><text class="section-title">Payment Methods</text></view><view data-event-opts="{{[['tap',[['selectPayment',['wechat']]]]]}}" class="payment-item" bindtap="__e"><image class="payment-icon" src="/static/images/icon/wechat-pay.png" mode="aspectFit"></image><text class="payment-name">WeChat Pay</text><view class="{{['payment-radio '+(paymentMethod==='wechat'?'selected':'')]}}"><block wx:if="{{paymentMethod==='wechat'}}"><text class="payment-check">✓</text></block></view></view><view class="payment-divider"></view><view data-event-opts="{{[['tap',[['selectPayment',['paynow']]]]]}}" class="payment-item" bindtap="__e"><image class="payment-icon" src="/static/images/icon/paynow.png" mode="aspectFit"></image><text class="payment-name">PayNow</text><view class="{{['payment-radio '+(paymentMethod==='paynow'?'selected':'')]}}"><block wx:if="{{paymentMethod==='paynow'}}"><text class="payment-check">✓</text></block></view></view></view><view class="section remark-section"><view class="section-header"><text class="section-title">Order Notes</text></view><textarea class="remark-input" placeholder="Add notes (optional)" maxlength="200" data-event-opts="{{[['input',[['inputRemark',['$event']]]]]}}" value="{{remark}}" bindinput="__e"></textarea></view><block wx:if="{{showTimePicker}}"><view data-event-opts="{{[['tap',[['cancelTime',['$event']]]]]}}" class="picker-overlay" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="picker-sheet" catchtap="__e"><view class="picker-header"><text class="picker-title">Select a time slot</text><text data-event-opts="{{[['tap',[['cancelTime',['$event']]]]]}}" class="picker-cancel" bindtap="__e">Cancel</text></view><scroll-view class="date-tabs" scroll-x="{{true}}" scroll-into-view="{{'date-tab-'+selectedDateIndex}}"><block wx:for="{{dateTabs}}" wx:for-item="tab" wx:for-index="i" wx:key="i"><view class="{{['date-tab '+(selectedDateIndex===i?'active':'')]}}" id="{{'date-tab-'+i}}" data-event-opts="{{[['tap',[['selectDateTab',[i]]]]]}}" bindtap="__e"><text class="date-tab-text">{{tab.label}}</text></view></block></scroll-view><view class="slots-list"><block wx:for="{{currentSlots}}" wx:for-item="slot" wx:for-index="i" wx:key="i"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({slot})}}" class="{{['slot-item '+(!slot.available?'unavailable':tempTime===slot.label?'selected':'')]}}" bindtap="__e"><view class="{{['slot-radio '+(tempTime===slot.label?'active':'')]}}"></view><text class="slot-label">{{slot.label}}</text><block wx:if="{{!slot.available}}"><text class="slot-na">Not available</text></block></view></block></view><view data-event-opts="{{[['tap',[['confirmTime',['$event']]]]]}}" class="{{['picker-confirm '+(tempTime?'':'disabled')]}}" bindtap="__e"><text>Confirm</text></view></view></view></block><view class="checkout-footer"><view data-event-opts="{{[['tap',[['submitOrder',['$event']]]]]}}" class="{{['submit-btn '+(submitting?'disabled':'')]}}" bindtap="__e"><text>{{submitting?'Processing...':'PAY $ '+totalPrice}}</text></view></view></view>